<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yaguareté RA - Experiencia Web</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar.js"></script>
</head>
<body style="margin: 0; overflow: hidden;">

    <a-scene embedded arjs="sourceType: webcam; debugUIEnabled: false;">
        
        <a-marker preset="hiro">
            
            <a-text value="YAGUARETE\nEn peligro critico" 
                    position="0 1.5 0" 
                    align="center" 
                    color="#FFCC00" 
                    scale="0.8 0.8 0.8">
            </a-text>

            <a-entity 
                gltf-model="url_de_tu_modelo_yaguarete.gltf"
                position="0 0 0"
                scale="0.5 0.5 0.5"
                animation__rotar="property: rotation; to: 0 360 0; loop: true; dur: 10000">
            </a-entity>

        </a-marker>

        <a-entity camera></a-entity>
        
    </a-scene>

</body>
</html>
